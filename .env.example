ADMIN_TOKEN=change-me

# Localhost URLs – used by host-side tools (alembic, local uvicorn, local frontend dev)
# The Docker backend container overrides these via docker-compose.yml environment block
DATABASE_URL=postgresql+asyncpg://halluzination:halluzination@localhost:5432/halluzination
REDIS_URL=redis://localhost:6379/0

POSTGRES_USER=halluzination
POSTGRES_PASSWORD=halluzination
POSTGRES_DB=halluzination

# Public domain for production (used by Caddy host, backend CORS/join URL, frontend origin)
APP_DOMAIN=localhost

ALLOWED_ORIGINS=["http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=uploads
